#include <iostream>
#include <iomanip>

using namespace std;

int main() {
    // ==========================================
    // Program 01: Bank Service Fees Calculator
    // ==========================================
    cout << "--- Program 01: Bank Service Fees ---" << endl;
    double balance, totalFee = 10.0;
    int checks;

    cout << "Enter beginning balance: ";
    cin >> balance;
    cout << "Enter number of checks written: ";
    cin >> checks;

    if (balance < 400) {
        totalFee += (checks * 0.10);
    } else if (checks >= 20 && checks <= 39) {
        totalFee += (checks * 0.08);
    } else if (checks >= 40 && checks <= 59) {
        totalFee += (checks * 0.06);
    } else if (checks >= 60) {
        totalFee += (checks * 0.04);
    }

    cout << fixed << setprecision(2);
    cout << "Total bank service fees for the month: \$ " << totalFee << endl << endl;

    // ==========================================
    // Program 02: Headphone Selection
    // ==========================================
    cout << "--- Program 02: Headphone Selection ---" << endl;
    int hpchoice;
    cout << "Headphone Type:\n1. Noise Canceling\n2. Wireless\n3. Wired Budget\n";
    cout << "Which headphone type do you want to buy? (1-3): ";
    cin >> hpchoice;

    if (hpchoice == 1) {
        cout << "Price: \$249.00\n";
    } else if (hpchoice == 2) {
        cout << "Price: \$199.00\n";
    } else if (hpchoice == 3) {
        cout << "Price: \$49.00\n";
    } else {
        cout << "Invalid choice\n";
    }
    cout << endl;

    // ==========================================
    // Program 03: Membership Pricing Calculator
    // ==========================================
    cout << "--- Program 03: Membership Calculator ---" << endl;
    int memchoice, months;
    double rate = 0;

    cout << "1. Standard Adult Membership\n2. Child Membership\n3. Senior Citizen Membership\n4. Quit\n";
    cout << "Enter your choice (1-4): ";
    cin >> memchoice;

    if (memchoice >= 1 && memchoice <= 3) {
        if (memchoice == 1) rate = 40.00;
        else if (memchoice == 2) rate = 20.00;
        else if (memchoice == 3) rate = 30.00;

        cout << "Enter the number of months you wish to join: ";
        cin >> months;

        cout << fixed << setprecision(2);
        cout << "Total amount to pay Rs. " << (rate * months) << endl;
    } else if (memchoice == 4) {
        cout << "Program ended.\n";
    } else {
        cout << "Invalid choice\n";
    }
    cout << endl;

    // ==========================================
    // Program 04: Internet Package Calculator
    // ==========================================
    cout << "--- Program 04: Internet Package ---" << endl;
    int pkg;
    double gb, billAmount = 0;

    cout << "Enter the package purchased (1, 2, or 3): ";
    cin >> pkg;
    cout << "Enter the number of gigabytes used: ";
    cin >> gb;

    if (pkg == 1) {
        billAmount = 39.99;
        if (gb > 4) billAmount += ((gb - 4) * 10);
    } else if (pkg == 2) {
        billAmount = 59.99;
        if (gb > 8) billAmount += ((gb - 8) * 5);
    } else if (pkg == 3) {
        billAmount = 69.99;
    } else {
        cout << "Invalid package.\n";
        return 0;
    }

    cout << fixed << setprecision(2);
    cout << "The total amount due is : \$" << billAmount << endl << endl;

    // ==========================================
    // Program 05: Seconds Converter
    // ==========================================
    cout << "--- Program 05: Seconds Converter ---" << endl;
    double seconds;
    cout << "Enter number of seconds: ";
    cin >> seconds;

    if (seconds >= 86400) {
        cout << "Days: " << (seconds / 86400) << endl;
    } else if (seconds >= 3600) {
        cout << "Hours: " << (seconds / 3600) << endl;
    } else if (seconds >= 60) {
        cout << "Minutes: " << (seconds / 60) << endl;
    } else {
        cout << "Seconds: " << seconds << endl;
    }

    return 0;
}
